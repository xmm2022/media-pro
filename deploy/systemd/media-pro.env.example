# Copy this file to /etc/media-pro/media-pro.env and edit values for the host.
# Do not commit real tokens, cookies, passwords, or private paths.

GATEWAY_DATABASE_URL=sqlite:////home/nax/media-pro/gateway.db
GATEWAY_COOKIE_SECRET=replace-me-with-a-long-random-secret

# Empty keeps /admin and /api/admin/* in local-development mode.
# Set a strong value before exposing the service beyond a trusted localhost.
GATEWAY_ADMIN_PASSWORD=replace-me-with-a-strong-admin-password
GATEWAY_ADMIN_SESSION_TTL_SECONDS=86400

# OpenList is commonly on 127.0.0.1:5246 in this deployment.
# Some existing OpenList installs use 5244; set this to the actual port.
GATEWAY_OPENLIST_BASE_URL=http://127.0.0.1:5246
GATEWAY_OPENLIST_TOKEN=replace-me
GATEWAY_OPENLIST_ADMIN_TOKEN=replace-me
GATEWAY_OPENLIST_COPY_VERIFY_ATTEMPTS=30
GATEWAY_OPENLIST_COPY_VERIFY_INTERVAL_SECONDS=1.0

GATEWAY_RAPID_COPY_BASE_URL=http://127.0.0.1:9000
GATEWAY_OPENLIST_PROBE_PATH=/Movies/sample.mkv
GATEWAY_CATALOG_ROOT_PATH=/Movies
GATEWAY_RAPID_COPY_DONOR_COOKIE=
GATEWAY_RAPID_COPY_TARGET_COOKIE=
GATEWAY_RAPID_COPY_SOURCE_PATH=/Movies/sample.mkv
GATEWAY_RAPID_COPY_TARGET_PATH=/EmbyCache/sample.mkv
