# 本机 OpenList 入口（POC 凭据从这里拿，不手动贴 cookie）
OPENLIST_BASE_URL=http://127.0.0.1:5244
OPENLIST_ADMIN_TOKEN=

# OpenList 里 2 个 139 storage 的 mount path（用于 T2/T3 区分 A/B 账号）
CAIYUN_STORAGE_A=/caiyun-a
CAIYUN_STORAGE_B=/caiyun-b

# OpenList 里 GD storage 的 mount path（T3 跨 storage copy 用）
GD_STORAGE_MOUNT=/gd

# T3 需要一个真实存在的样例文件（GD 上读、139 上写）
T3_SAMPLE_FILE=/sample.mkv
